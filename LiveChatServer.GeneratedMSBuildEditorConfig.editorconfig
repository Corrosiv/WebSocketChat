root = true

[*.cs]
charset = utf-8
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.{csproj,sln}]
indent_style = space
indent_size = 2

[*.{json,md}]
indent_style = space
indent_size = 2

# C# specific nullable and analyzer rules can be added here as needed
