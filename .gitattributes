# Normalize line endings and treat common text files as text
* text=auto eol=lf
\*.cs text eol=lf
\*.csproj text eol=lf
\*.sln text eol=lf
\*.md text eol=lf
\*.json text eol=lf
\*.xml text eol=lf
\*.yml text eol=lf
\*.yaml text eol=lf
\*.sh text eol=lf
\*.ps1 text eol=crlf
\*.png binary
\*.jpg binary
\*.jpeg binary
\*.gif binary
\*.ico binary
\*.pdf binary
\*.zip binary
